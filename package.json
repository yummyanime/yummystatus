{
    "name": "yummystatus",
    "version": "1.0.0",
    "description": "A simple service for monitoring website availability via HTTP requests using the globalping.io API.",
    "private": true,
    "type": "module",
    "scripts": {
        "start": "bun run start:server",
        "start:server": "bun server/index.js",
        "start:client": "bunx vite client --config client/vite.config.ts",
        "dev": "concurrently \"bun run start:client\" \"bun run start:server\"",
        "build": "tsc -b client && bunx vite build client --config client/vite.config.ts",
        "typecheck": "tsc -b client",
        "lint": "biome check .",
        "format": "biome format --write .",
        "preview": "bunx vite preview --config client/vite.config.ts",
        "prepare": "simple-git-hooks"
    },
    "simple-git-hooks": {
        "pre-commit": "bun run typecheck"
    },
    "dependencies": {
        "@tippyjs/react": "^4.2.6",
        "@types/leaflet": "^1.9.21",
        "axios": "^1.11.0",
        "chart.js": "^4.5.0",
        "chartjs-adapter-date-fns": "^3.0.0",
        "chartjs-plugin-crosshair": "^2.0.0",
        "classnames": "^2.5.1",
        "concurrently": "^9.2.1",
        "date-fns": "^4.1.0",
        "dotenv": "^17.2.1",
        "express": "^4.18.2",
        "leaflet": "^1.9.4",
        "node-fetch": "^2.7.0",
        "pg": "^8.16.3",
        "react": "^19.1.1",
        "react-chartjs-2": "^5.3.0",
        "react-country-flag": "^3.1.0",
        "react-dom": "^19.1.1",
        "react-leaflet": "^5.0.0",
        "react-router-dom": "^7.8.2",
        "socket.io-client": "^4.8.3"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.2.0",
        "@types/chartjs-plugin-crosshair": "^1.1.5",
        "@types/react": "^19.1.10",
        "@types/react-dom": "^19.1.7",
        "@vitejs/plugin-react": "^5.0.0",
        "sass": "^1.91.0",
        "simple-git-hooks": "^2.11.1",
        "typescript": "~5.8.3",
        "vite": "^7.1.2"
    }
}
